            <key code="20" output="Ю" />
            <key code="21" output="$" />
            <key code="22" output="^" />
            <key code="23" output="%" />
            <key code="24" output="З" />
            <key code="25" output="(" />
            <key code="26" output="&amp;" />
            <key code="27" output="_" />
            <key code="28" output="*" />
            <key code="29" output=")" />
            <key code="30" output="Ҳ" />
