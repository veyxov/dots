            <key code="43" output="," />
            <key code="44" output="?" />
            <key code="45" output="Н" />
            <key code="46" output="М" />
            <key code="47" output="?" />
            <key code="48" output="&#x09;" />
            <key code="49" output=" " />
            <key code="50" output="~" />
            <key code="57" output="Х" />
            <key code="123" output="ь" />
            <key code="51" output="&#x08;" /> <!-- Backspace -->
            <key code="53" output="&#x1B;" /> <!-- Escape -->
            <key code="115" output="&#x01;" /> <!-- Home -->
            <key code="116" output="&#x0B;" /> <!-- Page Up -->
            <key code="117" output="&#x7F;" /> <!-- Forward Delete -->
            <key code="119" output="&#x04;" /> <!-- End -->
            <key code="121" output="&#x0C;" /> <!-- Page Down -->
        </keyMap>

        <!-- Level 3: option (Tajik-only / extra letters; matches source's level3(ralt_switch)) -->
        <keyMap index="2">
            <key code="0" output="ғ" /> <!-- A -->
            <key code="1" output="с" /> <!-- S (no L3 in source, falls back) -->
            <key code="2" output="я" /> <!-- D (repurposed: source's DELE->я moved here, code117/Forward-Delete now stays plain delete) -->
            <key code="3" output="ф" /> <!-- F -->
            <key code="4" output="ъ" /> <!-- H -->
            <key code="5" output="ғ" /> <!-- G -->
            <key code="6" output="ж" /> <!-- Z -->
            <key code="7" output="х" /> <!-- X (no L3 in source, falls back) -->
            <key code="8" output="ч" /> <!-- C (no L3 in source, falls back) -->
            <key code="9" output="в" /> <!-- V -->
            <key code="11" output="б" /> <!-- B (no L3 in source, falls back) -->
            <key code="13" output="ц" /> <!-- W -->
            <key code="14" output="ё" /> <!-- E -->
            <key code="15" output="р" /> <!-- R -->
            <key code="16" output="щ" /> <!-- Y -->
            <key code="17" output="щ" /> <!-- T -->
            <key code="18" output="қ" /> <!-- 1 -->
