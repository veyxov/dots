<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE keyboard SYSTEM "file://localhost/System/Library/DTDs/KeyboardLayout.dtd">
<!--
  Ported from xkb/.xkb/symbols/rus ("Russian (Rulemak, phonetic Hands Down)").
  Same phonetic mapping (a->а, s->с, d->д, ...), same Tajik-only letters on
  Right-Option (ғ қ ӯ ҳ ҷ ӣ), same odd/duplicate slots as the source file —
  faithful port, not a redesign. Untouched keys (digits, punctuation not
  listed in the source) keep standard US output.

  Caveat: Caps Lock and Left Arrow overrides (from the source file's CAPS/LEFT
  entries) may not take effect — macOS handles both specially before the
  normal key-output pipeline runs. Included for fidelity; verify on device.
-->
<keyboard group="126" id="-19770" name="Russian-Tajik Phonetic (Hands Down)">

    <layouts>
        <layout first="0" last="123" modifiers="Modifiers" mapSet="ANSI" />
    </layouts>

    <modifierMap id="Modifiers" defaultIndex="0">
        <keyMapSelect mapIndex="0">
            <modifier keys="" />
        </keyMapSelect>
        <keyMapSelect mapIndex="1">
            <modifier keys="anyShift" />
        </keyMapSelect>
        <keyMapSelect mapIndex="2">
            <modifier keys="anyOption" />
        </keyMapSelect>
        <keyMapSelect mapIndex="3">
            <modifier keys="anyOption anyShift" />
        </keyMapSelect>
    </modifierMap>

    <keyMapSet id="ANSI">

        <!-- Level 1: unshifted -->
        <keyMap index="0">
            <key code="0" output="а" /> <!-- A -->
            <key code="1" output="с" /> <!-- S -->
            <key code="2" output="д" /> <!-- D -->
            <key code="3" output="ф" /> <!-- F -->
            <key code="4" output="ҳ" /> <!-- H -->
            <key code="5" output="г" /> <!-- G -->
            <key code="6" output="з" /> <!-- Z -->
            <key code="7" output="х" /> <!-- X -->
            <key code="8" output="ч" /> <!-- C -->
            <key code="9" output="в" /> <!-- V -->
            <key code="11" output="б" /> <!-- B -->
            <!-- code 12 (Q) intentionally undefined, matches source's disabled AD01 -->
            <key code="13" output="ш" /> <!-- W -->
            <key code="14" output="е" /> <!-- E -->
            <key code="15" output="р" /> <!-- R -->
            <key code="16" output="й" /> <!-- Y -->
            <key code="17" output="т" /> <!-- T -->
            <key code="18" output="қ" /> <!-- 1 -->
            <key code="19" output="ҷ" /> <!-- 2 -->
            <key code="20" output="ю" /> <!-- 3 -->
            <key code="21" output="4" />
            <key code="22" output="6" />
            <key code="23" output="5" />
            <key code="24" output="з" /> <!-- = -->
            <key code="25" output="9" />
            <key code="26" output="7" />
            <key code="27" output="-" />
            <key code="28" output="8" />
            <key code="29" output="0" />
            <key code="30" output="ҳ" /> <!-- ] -->
            <key code="31" output="о" /> <!-- O -->
            <key code="32" output="у" /> <!-- U -->
            <key code="33" output="и" /> <!-- [ -->
            <key code="34" output="и" /> <!-- I -->
            <key code="35" output="п" /> <!-- P -->
            <key code="36" output="&#x0d;" /> <!-- Return -->
            <key code="37" output="л" /> <!-- L -->
            <key code="38" output="қ" /> <!-- J -->
            <key code="39" output="ы" /> <!-- ' -->
            <key code="40" output="к" /> <!-- K -->
            <key code="41" output="Ъ" /> <!-- ; -->
            <key code="42" output="\" />
            <key code="43" output="," />
            <key code="44" output="/" />
            <key code="45" output="н" /> <!-- N -->
            <key code="46" output="м" /> <!-- M -->
            <key code="47" output="." />
            <key code="48" output="&#x09;" /> <!-- Tab -->
            <key code="49" output=" " /> <!-- Space -->
            <key code="50" output="`" />
            <key code="57" output="х" /> <!-- Caps Lock -->
            <key code="123" output="ь" /> <!-- Left Arrow -->
            <key code="51" output="&#x08;" /> <!-- Backspace -->
            <key code="53" output="&#x1B;" /> <!-- Escape -->
            <key code="115" output="&#x01;" /> <!-- Home -->
            <key code="116" output="&#x0B;" /> <!-- Page Up -->
            <key code="117" output="&#x7F;" /> <!-- Forward Delete -->
            <key code="119" output="&#x04;" /> <!-- End -->
            <key code="121" output="&#x0C;" /> <!-- Page Down -->
        </keyMap>

        <!-- Level 2: shift -->
        <keyMap index="1">
            <key code="0" output="А" />
            <key code="1" output="С" />
            <key code="2" output="Д" />
            <key code="3" output="Ф" />
            <key code="4" output="Ҳ" />
            <key code="5" output="Г" />
