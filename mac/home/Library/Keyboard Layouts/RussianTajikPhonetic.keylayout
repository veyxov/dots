            <key code="24" output="з" />
            <key code="25" output="9" />
            <key code="26" output="7" />
            <key code="27" output="-" />
            <key code="28" output="8" />
            <key code="29" output="0" />
            <key code="30" output="«" /> <!-- ] -->
            <key code="31" output="о" />
            <key code="32" output="ӯ" /> <!-- U -->
            <key code="33" output="ӣ" /> <!-- [ -->
            <key code="34" output="ӣ" /> <!-- I -->
            <key code="35" output="ё" /> <!-- P -->
            <key code="36" output="&#x0d;" />
            <key code="37" output="ӯ" /> <!-- L -->
            <key code="38" output="қ" /> <!-- J -->
            <key code="39" output="ы" /> <!-- ' -->
            <key code="40" output="к" /> <!-- K (no L3 in source, falls back) -->
            <key code="41" output="ӣ" /> <!-- ; -->
            <key code="42" output="\" />
            <key code="43" output="," />
            <key code="44" output="&gt;" /> <!-- / -->
            <key code="45" output="\" /> <!-- N -->
            <key code="46" output="м" /> <!-- M (no L3 in source, falls back) -->
            <key code="47" output="&lt;" /> <!-- . -->
            <key code="48" output="&#x09;" />
            <key code="49" output=" " />
            <key code="50" output="`" />
            <key code="57" output="х" />
            <key code="123" output="ь" />
            <key code="51" output="&#x08;" /> <!-- Backspace -->
            <key code="53" output="&#x1B;" /> <!-- Escape -->
            <key code="115" output="&#x01;" /> <!-- Home -->
            <key code="116" output="&#x0B;" /> <!-- Page Up -->
            <key code="117" output="&#x7F;" /> <!-- Forward Delete -->
            <key code="119" output="&#x04;" /> <!-- End -->
            <key code="121" output="&#x0C;" /> <!-- Page Down -->
        </keyMap>

        <!-- Level 4: option+shift -->
        <keyMap index="3">
            <key code="0" output="Ғ" />
            <key code="1" output="С" /> <!-- no L4 in source, falls back to L2 -->
            <key code="2" output="Я" /> <!-- repurposed, see Level 3 code 2 -->
            <key code="3" output="Ф" />
            <key code="4" output="Ъ" />
            <key code="5" output="Ғ" />
            <key code="6" output="Ж" />
            <key code="7" output="Х" />
