theme = Catppuccin Mocha
background-opacity = 0.85
background-blur-radius = 20
minimum-contrast = 1.05

macos-titlebar-style = hidden
macos-option-as-alt = true
mouse-hide-while-typing = true
confirm-close-surface = false
quit-after-last-window-closed = true
font-thicken = true

# quake-style dropdown terminal
keybind = global:cmd+grave_accent=toggle_quick_terminal

# font size
keybind = alt+slash=increase_font_size:2
keybind = alt+shift+slash=decrease_font_size:2

# clipboard: ctrl+c copies only when selection exists, else passes SIGINT through
keybind = performable:ctrl+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard

# ctrl/alt+backspace delete word
keybind = ctrl+backspace=text:\x17
keybind = alt+backspace=text:\x17
