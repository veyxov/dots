[gpg]
	format = ssh

[merge]
    conflictstyle = diff3

[user]
	email = veyxov@gmail.com
	name = Shekhov Ismoil
	signingkey = ~/.ssh/id_ed25519.pub
[push]
    autoSetupRemote = true
[init]
    defaultBranch = main
[alias]
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
[diff]
    colorMoved = zebra
[core]
	pager = delta
	excludesfile = ~/.config/git/ignore
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	plus-color = "#a6e3a1"
	plus-emph-color = "#40a02b"
	minus-color = "#f38ba8"
	minus-emph-color = "#d20f39"
	line-numbers-plus-style = "#a6e3a1"
	line-numbers-minus-style = "#f38ba8"
	line-numbers-zero-style = "#6c7086"
[rebase]
	autosquash = true
[fetch]
	prune = true
[help]
	autocorrect = 20
[pull]
    rebase = true

[commit]
	gpgsign = true
[credential]
	useHttpPath = true
[rerere]
	enabled = true
