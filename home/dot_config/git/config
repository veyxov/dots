[gpg]
	format = ssh

[merge]
    conflictstyle = diff3

[user]
	email = veyxov@gmail.com
	name = Shekhov Ismoil
	signingkey = ~/.ssh/id_ed25519.pub
[push]
    autoSetupRemote = true
[init]
    defaultBranch = main
[alias]
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
[diff]
    colorMoved = zebra
[rebase]
	autosquash = true
[fetch]
	prune = true
[help]
	autocorrect = 20
[pull]
    rebase = true

[commit]
	gpgsign = true
[credential]
	useHttpPath = true
